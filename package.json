{
    "name": "@adguard/diff-builder",
    "version": "1.1.4",
    "description": "A tool for generating differential updates for filter lists.",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/AdguardTeam/DiffBuilder.git"
    },
    "bugs": {
        "url": "https://github.com/AdguardTeam/DiffBuilder/issues"
    },
    "homepage": "https://github.com/AdguardTeam/DiffBuilder#readme",
    "author": "AdGuard",
    "license": "MIT",
    "main": "dist/api/builder/cjs/index.js",
    "types": "dist/types/diff-builder/index.d.ts",
    "files": [
        "dist",
        "src"
    ],
    "exports": {
        ".": {
            "types": "./dist/types/diff-builder/index.d.ts",
            "default": "./dist/api/builder/cjs/index.js"
        },
        "./es": {
            "types": "./dist/types/diff-builder/index.d.ts",
            "default": "./dist/api/builder/es/index.js"
        },
        "./diff-updater": {
            "types": "./dist/types/diff-updater/index.d.ts",
            "default": "./dist/api/updater/cjs/index.js"
        },
        "./diff-updater/es": {
            "types": "./dist/types/diff-updater/index.d.ts",
            "default": "./dist/api/updater/es/index.js"
        }
    },
    "typesVersions": {
        "*": {
            "es": [
                "dist/types/diff-builder/index.d.ts"
            ],
            "diff-updater": [
                "dist/types/diff-updater/index.d.ts"
            ],
            "diff-updater/es": [
                "dist/types/diff-updater/index.d.ts"
            ]
        }
    },
    "bin": {
        "diff-builder": "dist/bin/diff-builder"
    },
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "prebuild": "rimraf dist && pnpm build:types",
        "build": "rollup -c rollup.config.ts --configPlugin typescript",
        "postbuild": "ts-node tasks/build-txt",
        "watch": "rollup -c rollup.config.ts --configPlugin typescript -w",
        "build:types": "tsc --project tsconfig.build.json --declaration --emitDeclarationOnly --outdir dist/types",
        "lint": "pnpm lint:code && pnpm lint:types && pnpm lint:md",
        "lint:code": "eslint --cache .",
        "lint:types": "tsc --noEmit",
        "lint:md": "markdownlint .",
        "test": "jest",
        "test:smoke": "(cd tests/smoke/cjs && pnpm test) && (cd tests/smoke/esm && pnpm test) && (cd tests/smoke/typescript && pnpm test)",
        "increment": "pnpm version patch --no-git-tag-version",
        "tgz": "pnpm pack --out diff-builder.tgz"
    },
    "dependencies": {
        "commander": "^11.1.0",
        "crypto-js": "^4.2.0"
    },
    "devDependencies": {
        "@rollup/plugin-commonjs": "^25.0.7",
        "@rollup/plugin-json": "^6.0.1",
        "@rollup/plugin-node-resolve": "^15.2.3",
        "@rollup/plugin-typescript": "^11.1.5",
        "@swc/core": "^1.3.95",
        "@swc/jest": "^0.2.29",
        "@types/crypto-js": "^4.2.1",
        "@types/express": "^4.17.21",
        "@types/jest": "^29.5.6",
        "@types/node": "^20.8.7",
        "@typescript-eslint/eslint-plugin": "^6.9.0",
        "@typescript-eslint/parser": "^6.9.0",
        "esbuild": "^0.19.5",
        "esbuild-register": "^3.5.0",
        "eslint": "^8.52.0",
        "eslint-config-airbnb-typescript": "^17.1.0",
        "eslint-plugin-import": "^2.29.0",
        "eslint-plugin-import-newlines": "^1.3.4",
        "eslint-plugin-jsdoc": "^46.8.2",
        "express": "^4.18.2",
        "jest": "^29.7.0",
        "markdownlint": "^0.40.0",
        "markdownlint-cli": "^0.48.0",
        "rimraf": "^6.0.1",
        "rollup": "^4.1.4",
        "rollup-plugin-cleanup": "^3.2.1",
        "rollup-plugin-preserve-shebangs": "^0.2.0",
        "ts-node": "^10.9.1",
        "tslib": "^2.6.2",
        "typescript": "^5.2.2"
    }
}
